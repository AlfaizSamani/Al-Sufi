# ─── DATABASE ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-super-secret-db-password
POSTGRES_PORT=5432

# ─── API GATEWAY (KONG) ───────────────────────────────────────────────────────
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# ─── AUTH (GOTRUE) ────────────────────────────────────────────────────────────
SITE_URL=http://localhost:8080
JWT_SECRET=your-32th-character-jwt-secret
JWT_EXPIRY=3600
OPERATOR_TOKEN=your-random-operator-token
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

# ─── SMTP (Optional, but recommended) ────────────────────────────────────────
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SENDER_NAME=Al-Sufi Connect

# ─── KEYS (Generate these) ────────────────────────────────────────────────────
# You can generate these using a tool like: https://generate-secret.vercel.app/
ANON_KEY=your-generated-anon-key
SERVICE_ROLE_KEY=your-generated-service-role-key

# ─── STORAGE ──────────────────────────────────────────────────────────────────
STORAGE_S3_KEY=none
STORAGE_S3_SECRET=none
STORAGE_S3_REGION=none
STORAGE_S3_BUCKET=none

# ─── STUDIO ───────────────────────────────────────────────────────────────────
STUDIO_PORT=3000
